# Fill in after running contract/script/Deploy.s.sol on Arc Testnet
NEXT_PUBLIC_STREAM_VAULT_ADDRESS=
NEXT_PUBLIC_BATCH_STREAM_ADDRESS=
# USDC on Arc Testnet (same asset as the native gas token)
NEXT_PUBLIC_ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000

# Circle API key — shared by both Payouts and Wallets below
CIRCLE_API_KEY=

# Circle Payouts (offramp) — leave empty for demo mode
# CIRCLE_PAYOUTS_API_BASE=https://api.circle.com  # defaults to sandbox host

# Circle Programmable Wallets — User-Controlled (recipient sign-up + PIN wallets)
# Get an App ID from console.circle.com → Wallets → User Controlled → Configurator
# CIRCLE_WALLETS_API_BASE=https://api.circle.com  # this is the default already;
# sandbox vs production is determined by which API key you use, not the host

# Supabase — businesses, recipient directory, invites
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Enable Google sign-in for recipients in the Supabase Auth dashboard
# (Authentication > Providers > Google)

# SMTP (nodemailer) — recipient invite emails, leave empty for demo mode (logs the link)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# SMTP_SECURE=true  # set for port 465
